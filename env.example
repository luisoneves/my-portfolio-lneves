# ============================================================
# .env.example — Portfolio dev-luisneves.me
# Copiar para .env.local e preencher com valores reais.
# Este arquivo É commitado — não colocar valores reais aqui.
# ============================================================

# --- Resend (formulário de contato) ---
# Obter em: resend.com → API Keys
RESEND_API_KEY=

# Email de destino das mensagens do formulário de contato
CONTACT_TO_EMAIL=

# --- Microsoft Clarity ---
# Opcional: move o Project ID de hardcoded no ClarityProvider para env var
# Se não definido, o componente usa o valor hardcoded (vw2ovtzbwy)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
